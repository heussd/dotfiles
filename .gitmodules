[submodule "_externals/my-way-to-view-things"]
	path = .dotfiles-externals/my-way-to-view-things
	url = https://github.com/heussd/my-way-to-view-things.git
[submodule ".zsh/zsh-autosuggestions"]
	path = .zsh/zsh-autosuggestions
	url = https://github.com/zsh-users/zsh-autosuggestions
[submodule ".zsh/fzf-tab"]
	path = .zsh/fzf-tab
	url = https://github.com/Aloxaf/fzf-tab
[submodule ".zsh/zsh-syntax-highlighting"]
	path = .zsh/zsh-syntax-highlighting
	url = https://github.com/zsh-users/zsh-syntax-highlighting
[submodule ".zsh/zsh-completions"]
	path = .zsh/zsh-completions
	url = https://github.com/zsh-users/zsh-completions
[submodule ".zsh/zsh-fzf-history-search"]
	path = .zsh/zsh-fzf-history-search
	url = https://github.com/joshskidmore/zsh-fzf-history-search
